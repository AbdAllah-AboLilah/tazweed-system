rules_version = '2';

// قواعد أمان Firestore — طبقًا لملف المواصفات (قسم 4: الأدوار والصلاحيات)
// المرحلة 3: نظام النواقص — إضافة انتقالات حالة status محدّدة لأمين الفرع
// (طلب/إلغاء تزويد) وأمين الرئيسي (تزويد/تصفير/إرجاع)، فوق تعديل الكميات.
// + إضافة أحدث: طلبات الطباعة عن بُعد (printJobs) لإرسال طباعة لمكان تاني.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function role() {
      return userProfile().role;
    }

    function isAdmin() {
      return isSignedIn() && role() == 'admin';
    }

    // مدير الفرع والمشرف: كل الصلاحيات مؤقتًا (سيُخصَّص لاحقًا حسب الاتفاق)
    function isFullAccess() {
      return isSignedIn() && role() in ['admin', 'branch_manager', 'supervisor'];
    }

    function warehouseAccess() {
      return userProfile().warehouseAccess;
    }

    function isBranchKeeper() {
      return role() == 'warehouse_keeper' && warehouseAccess() in ['branch', 'both'];
    }

    function isMainKeeper() {
      return role() == 'warehouse_keeper' && warehouseAccess() in ['main', 'both'];
    }

    function onlyChangedKeys(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    function oldStatus() { return resource.data.status; }
    function newStatus() { return request.resource.data.status; }

    // أمين مخزن الفرع: يعدّل branchQty، أو يطلب تزويد (عادي → معلّق)،
    // أو يلغي طلبه (معلّق → عادي).
    function branchAction() {
      return isBranchKeeper() && (
        onlyChangedKeys(['branchQty'])
        || (onlyChangedKeys(['status']) && oldStatus() == 'normal' && newStatus() == 'pending')
        || (onlyChangedKeys(['status']) && oldStatus() == 'pending' && newStatus() == 'normal')
      );
    }

    // أمين المخزن الرئيسي: يعدّل mainQty، أو يرد على طلب معلّق (تزويد فعلي
    // بنقل كمية، أو تصفير كامل لو مفيش عنده حاجة)، أو يرجّع درجة خلصت لتبقى متاحة.
    function mainAction() {
      return isMainKeeper() && (
        onlyChangedKeys(['mainQty'])
        || (onlyChangedKeys(['status', 'mainQty', 'branchQty']) && oldStatus() == 'pending' && newStatus() == 'normal')
        || (onlyChangedKeys(['status']) && oldStatus() == 'pending' && newStatus() == 'out')
        || (onlyChangedKeys(['status']) && oldStatus() == 'out' && newStatus() == 'normal')
      );
    }

    function canUpdateGrade() {
      return isFullAccess() || branchAction() || mainAction();
    }

    // حسابات المستخدمين: القراءة لأي مستخدم مسجّل دخول (عشان نعرض الاسم/الدور)،
    // والكتابة (إنشاء/تعديل/حذف حسابات) للمدير فقط.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isFullAccess();

      match /grades/{gradeId} {
        allow read: if isSignedIn();
        allow create, delete: if isFullAccess();
        allow update: if canUpdateGrade();
      }
    }

    // سجل العمليات: أي مستخدم مسجّل دخول يقدر يضيف سجل (وقت تعديله هو نفسه)
    // ويقرأ السجل، لكن محدش يقدر يعدّل أو يمسح سجل قديم — عشان يفضل موثوق.
    match /activityLog/{entryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // طلبات الطباعة عن بُعد: الإنشاء بس لمستخدمين معينين (canSendRemotePrint)
    // أو أصحاب الصلاحية الكاملة. أي مستخدم مسجّل دخول يقدر "يستلم" الطلب
    // ويعلّمه كـ printed (الجهاز المستقبِل)، لكن مش يغيّر حاجة تانية غير كده.
    function canSendPrintJob() {
      return isFullAccess() || userProfile().canSendRemotePrint == true;
    }

    match /printJobs/{jobId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && canSendPrintJob() && request.resource.data.requestedByUid == request.auth.uid;
      allow update: if isSignedIn()
        && onlyChangedKeys(['status', 'printedByUid', 'printedByName', 'printedAt'])
        && oldStatus() == 'pending' && newStatus() == 'printed';
      allow delete: if isFullAccess();
    }
  }
}
